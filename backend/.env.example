# Production Ready NL2SQL configuration catalog
# Copy only deployment-specific values to .env. Keep every secret, OCID and DSN empty here.

# Application
APP_VERSION=0.1.0
LOG_LEVEL=INFO
ENVIRONMENT=local
SERVICE_NAME=production-ready-nl2sql
CORS_ORIGINS=["http://localhost:3001","http://127.0.0.1:5173","http://127.0.0.1:3001"]
ENABLE_METRICS=true
# DEBUG=true is permitted only with ENVIRONMENT=local and grants the local SYSTEM_ADMIN identity.
DEBUG=true

# Authentication / RBAC
APP_AUTH_ENABLED=true
APP_AUTH_COOKIE_SECURE=false
APP_AUTH_SESSION_COOKIE_NAME=nl2sql_session
APP_AUTH_CSRF_COOKIE_NAME=nl2sql_csrf
APP_AUTH_IDLE_TIMEOUT_MINUTES=30
APP_AUTH_ABSOLUTE_TIMEOUT_HOURS=12
APP_AUTH_FAILED_LOGIN_LIMIT=5
APP_AUTH_LOCKOUT_MINUTES=15
APP_AUTH_PASSWORD_MIN_LENGTH=12
APP_AUTH_PASSWORD_MAX_LENGTH=128
APP_AUTH_ARGON2_TIME_COST=3
APP_AUTH_ARGON2_MEMORY_KIB=65536
APP_AUTH_ARGON2_PARALLELISM=4

# Oracle 26ai
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_DSN=
ORACLE_DRIVER_MODE=thick
ORACLE_CLIENT_LIB_DIR=/u01/aipoc/instantclient_23_26
ORACLE_WALLET_DIR=
ORACLE_WALLET_PASSWORD=
ORACLE_DB_TEST_TIMEOUT_SECONDS=15
ORACLE_TCP_CONNECT_TIMEOUT_SECONDS=10
ORACLE_DEEPSEC_ENABLED=false
ORACLE_DEEPSEC_END_USER=NL2SQL_APP_END_USER
ORACLE_DEEPSEC_END_USER_PASSWORD=
ORACLE_ADB_OCID=
ORACLE_ADB_REGION=

# OCI identity
OCI_REGION=
OCI_COMPARTMENT_ID=
OCI_CONFIG_FILE=~/.oci/config
OCI_CONFIG_PROFILE=DEFAULT
# Deprecated compatibility fallback. Use OCI_CONFIG_PROFILE for new deployments.
OCI_PROFILE=
OCI_AUTH_MODE=config_file
OCI_USER_OCID=
OCI_FINGERPRINT=
OCI_TENANCY_OCID=
OCI_KEY_FILE=

# Model settings
# Non-sensitive model values are persisted by the UI in MODEL_SETTINGS_FILE (schema v2).
# OCI_ENTERPRISE_AI_API_KEY is the only supported source for this secret.
MODEL_SETTINGS_FILE=model-settings.json
OCI_ENTERPRISE_AI_ENDPOINT=
OCI_ENTERPRISE_AI_PROJECT_OCID=
OCI_ENTERPRISE_AI_API_KEY=
OCI_ENTERPRISE_AI_MODELS=[]
OCI_ENTERPRISE_AI_DEFAULT_MODEL=
OCI_ENTERPRISE_AI_LLM_MODEL=
OCI_ENTERPRISE_AI_LLM_PATH=/responses
OCI_ENTERPRISE_AI_LLM_PAYLOAD_TEMPLATE=
OCI_ENTERPRISE_AI_LLM_RESPONSE_PATH=
OCI_ENTERPRISE_AI_VLM_MODEL=
OCI_ENTERPRISE_AI_VLM_PATH=/responses
OCI_ENTERPRISE_AI_VLM_PAYLOAD_TEMPLATE=
OCI_ENTERPRISE_AI_VLM_RESPONSE_PATH=
OCI_ENTERPRISE_AI_VLM_INPUT_MODE=auto
OCI_ENTERPRISE_AI_TIMEOUT_SECONDS=600
OCI_ENTERPRISE_AI_MAX_RETRIES=3
OCI_ENTERPRISE_AI_LLM_MAX_OUTPUT_TOKENS=1200
OCI_ENTERPRISE_AI_VLM_MAX_OUTPUT_TOKENS=65536

# OCI Generative AI (embedding / rerank only)
OCI_GENAI_ENDPOINT=
OCI_GENAI_EMBEDDING_MODEL=cohere.embed-v4.0
OCI_GENAI_EMBEDDING_DIM=1536
OCI_GENAI_RERANK_MODEL=cohere.rerank-v4.0-fast
OCI_GENAI_EMBED_MODEL_ID=cohere.embed-v4.0
OCI_GENAI_RERANK_MODEL_ID=cohere.rerank-v4.0-fast

# Upload / Object Storage
UPLOAD_STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=/u01/production-ready-nl2sql
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_NAMESPACE=
OBJECT_STORAGE_BUCKET=nl2sql-originals
MAX_UPLOAD_BYTES=209715200

# NL2SQL runtime and persistence
NL2SQL_ALLOW_SELECT_ONLY=true
NL2SQL_DEFAULT_ROW_LIMIT=100
NL2SQL_RUNTIME_MODE=deterministic
NL2SQL_PERSISTENCE_MODE=oracle
NL2SQL_ORACLE_STATE_TABLE=NL2SQL_STATE_STORE
NL2SQL_STATE_BACKEND=incremental
NL2SQL_MIGRATION_MIRROR_ENABLED=false
NL2SQL_CACHE_TTL_SECONDS=5
NL2SQL_PROFILE_CACHE_MAX_ENTRIES=1000
NL2SQL_SCHEMA_OBJECT_CACHE_MAX_ENTRIES=500
NL2SQL_SCHEMA_REFRESH_WORKER_ENABLED=true
NL2SQL_SCHEMA_REFRESH_LEASE_SECONDS=900
NL2SQL_ORACLE_CONNECT_TIMEOUT_SECONDS=5
NL2SQL_CSV_IMPORT_MAX_ROWS=5000
NL2SQL_CSV_IMPORT_MAX_COLUMNS=200

# Ontology
NL2SQL_ONTOLOGY_GRAPH_CACHE_MAX_REVISIONS=3
NL2SQL_ONTOLOGY_GRAPH_CACHE_MAX_MEGABYTES=256
NL2SQL_ONTOLOGY_WORKER_MODE=inprocess
NL2SQL_ONTOLOGY_WORKER_POLL_SECONDS=1
NL2SQL_ONTOLOGY_WORKER_CLAIM_TIMEOUT_SECONDS=900
NL2SQL_ONTOLOGY_REASONING_PROFILE=owl2rl
NL2SQL_ONTOLOGY_SHACL_ENABLED=true
NL2SQL_ONTOLOGY_RDF_NETWORK_OWNER=
NL2SQL_ONTOLOGY_RDF_NETWORK_NAME=
NL2SQL_ONTOLOGY_PROFILE_CONFIRMATION_REQUIRED=true
NL2SQL_ONTOLOGY_CONFIRMATION_TTL_SECONDS=900

# Select AI / schema catalog
NL2SQL_SELECT_AI_ENABLED=true
NL2SQL_SELECT_AI_AGENT_ENABLED=true
NL2SQL_ENTERPRISE_AI_DIRECT_ENABLED=true
NL2SQL_SELECT_AI_PROFILE_PREFIX=NL2SQL
NL2SQL_SELECT_AI_PROVIDER=oci
NL2SQL_SELECT_AI_CREDENTIAL_NAME=
NL2SQL_SELECT_AI_MODEL=
NL2SQL_SCHEMA_OWNER_ALLOWLIST=[]
NL2SQL_SCHEMA_SAMPLE_ROWS=3
NL2SQL_SCHEMA_SAMPLE_COLUMNS_PER_TABLE=6

# Feedback embedding
NL2SQL_FEEDBACK_EMBEDDING_ENABLED=false
NL2SQL_FEEDBACK_VECTOR_TABLE=NL2SQL_FEEDBACK_VECTORS
NL2SQL_FEEDBACK_VECTOR_INDEX=NL2SQL_FEEDBACK_VEC_IDX
